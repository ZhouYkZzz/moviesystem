<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moviesystem.mapper.UserRecoMapper">

    <select id="getRecoJson" resultType="string">
        SELECT CAST(reco_json AS CHAR)
        FROM user_reco
        WHERE user_id = #{userId}
        LIMIT 1
    </select>

</mapper>
